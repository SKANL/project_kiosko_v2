@page "/"
@inject NavigationManager Nav

<PageTitle>Nodus — Inicio</PageTitle>

<div class="centered-message">
    <div class="card" style="max-width: 400px; text-align: center;">
        <h2>¡Bienvenido a Nodus!</h2>
        <p>Para registrar tu proyecto, por favor <strong>escanea el código QR</strong> proporcionado por el organizador del evento.</p>
        <p style="font-size: 0.9em; opacity: 0.8; margin-top: 1rem;">
            El código QR contiene la información necesaria (ID del evento y servidor local) para conectarte correctamente.
        </p>
    </div>
</div>
