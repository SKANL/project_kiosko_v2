<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Nodus.Admin.Presentation.Views.ManageJudgesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Nodus.Admin.Presentation.ViewModels"
    x:DataType="vm:ManageJudgesViewModel"
    Title="Jueces"
    BackgroundColor="{AppThemeBinding Light={StaticResource NodusBackground}, Dark={StaticResource NodusBackgroundDark}}">

    <Grid RowDefinitions="Auto,*">
        
        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="16,12,16,0">
            <VerticalStackLayout Spacing="2">
                <Label Text="Lista de Jueces" Style="{StaticResource Headline}" />
                <Label Text="Administra y bloquea el acceso de los jueces." Style="{StaticResource Caption1}" TextColor="{StaticResource NodusSecondaryLabel}" />
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1" Padding="0,12,0,24">
            <VerticalStackLayout Spacing="0">
                <CollectionView ItemsSource="{Binding Judges}" SelectionMode="None" Margin="16,0">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <Label Text="No hay jueces registrados en este evento." Style="{StaticResource Footnote}" HorizontalTextAlignment="Center" Margin="0,20"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ManageJudgeItem">
                            <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,2">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                                        <Label Text="{Binding Judge.Name}" Style="{StaticResource Headline}" />
                                        <Label Text="{Binding Judge.Institution}" Style="{StaticResource Footnote}" TextColor="{StaticResource NodusSecondaryLabel}" />
                                    </VerticalStackLayout>
                                    
                                    <Border Grid.Column="1" Grid.Row="0" BackgroundColor="{Binding BlockStatusColor}"
                                            StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="10,4" VerticalOptions="Start">
                                        <Label Text="{Binding BlockStatusLabel}" TextColor="White" FontSize="12" FontAttributes="Bold" />
                                    </Border>

                                    <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding BlockActionText}" Command="{Binding ToggleBlockCommand}" 
                                            Style="{StaticResource GhostButton}" HorizontalOptions="End" Margin="0,8,0,0" Padding="8,4" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
