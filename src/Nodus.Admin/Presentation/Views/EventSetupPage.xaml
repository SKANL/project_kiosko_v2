<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Nodus.Admin.Presentation.ViewModels"
             xmlns:entities="clr-namespace:Nodus.Admin.Domain.Entities"
             xmlns:conv="clr-namespace:Nodus.Admin.Presentation.Converters"
             x:Class="Nodus.Admin.Presentation.Views.EventSetupPage"
             x:Name="PageRoot"
             x:DataType="vm:EventSetupViewModel"
             Title="Preparar evento"
             BackgroundColor="{AppThemeBinding Light={StaticResource NodusBackground}, Dark={StaticResource NodusBackgroundDark}}">

    <ContentPage.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <conv:BooleanToColorConverter x:Key="BooleanToColorConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *, Auto">
        
        <!-- Header & Progress -->
        <VerticalStackLayout Grid.Row="0" Padding="24,20,24,10" Spacing="12">
            <Grid ColumnDefinitions="*, Auto">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="Preparar evento" Style="{StaticResource Title2}" />
                    <Label Text="Sigue los pasos para configurar tu evento" Style="{StaticResource Subhead}" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="Cerrar" Command="{Binding DoneCommand}" Style="{StaticResource GhostButton}" VerticalOptions="Start" />
            </Grid>
            
            <ProgressBar Progress="{Binding StepProgress}" HeightRequest="4" Margin="0,10,0,0" />
            
            <Grid ColumnDefinitions="*,*,*">
                <Label Grid.Column="0" Text="1. Detalles" Style="{StaticResource WizardLabel}" 
                       TextColor="{Binding IsStep1, Converter={StaticResource BooleanToColorConverter}, ConverterParameter={StaticResource NodusAccent}}" />
                <Label Grid.Column="1" Text="2. Rúbrica" Style="{StaticResource WizardLabel}"
                       TextColor="{Binding IsStep2, Converter={StaticResource BooleanToColorConverter}, ConverterParameter={StaticResource NodusAccent}}" />
                <Label Grid.Column="2" Text="3. Finalizar" Style="{StaticResource WizardLabel}"
                       TextColor="{Binding IsStep3, Converter={StaticResource BooleanToColorConverter}, ConverterParameter={StaticResource NodusAccent}}" />
            </Grid>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,10,20,40" Spacing="24">

                <!-- STEP 1: EVENT DETAILS -->
                <VerticalStackLayout Spacing="20" IsVisible="{Binding IsStep1}">
                    <Border Style="{StaticResource PremiumCard}">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="INFORMACIÓN GENERAL" Style="{StaticResource SectionHeader}" Margin="0,0,0,8" />
                            
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Nombre del evento" Style="{StaticResource FormLabel}" />
                                <Entry Placeholder="Ej. Intercolegial de Robótica" Text="{Binding EventName}" Style="{StaticResource FormEntry}" Margin="0" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="Institución / Sede" Style="{StaticResource FormLabel}" />
                                <Entry Placeholder="Ej. Campus Central" Text="{Binding Category}" Style="{StaticResource FormEntry}" Margin="0" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="Descripción corta" Style="{StaticResource FormLabel}" />
                                <Entry Placeholder="Resumen para los participantes" Text="{Binding Description}" Style="{StaticResource FormEntry}" Margin="0" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource PremiumCard}">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="CONFIGURACIÓN DE REGISTRO" Style="{StaticResource SectionHeader}" Margin="0,0,0,8" />

                            <VerticalStackLayout Spacing="8">
                                <Label Text="Categorías del evento" Style="{StaticResource FormLabel}" />
                                
                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                    <Entry Grid.Column="0" Placeholder="Nueva categoría (P. ej: IA)" Text="{Binding NewCategoryName}" Style="{StaticResource FormEntry}" ReturnCommand="{Binding AddCategoryCommand}" />
                                    <Button Grid.Column="1" Text="Añadir" Command="{Binding AddCategoryCommand}" Style="{StaticResource SecondaryButton}" VerticalOptions="Center" />
                                </Grid>

                                <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start" AlignItems="Center" BindableLayout.ItemsSource="{Binding CategoryList}" Margin="0,8">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Border StrokeShape="RoundRectangle 20" Padding="12,6" Margin="0,0,8,8" BackgroundColor="{StaticResource NodusAccentSurface}">
                                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                                    <Label Text="{Binding .}" TextColor="{StaticResource NodusAccent}" FontAttributes="Bold" VerticalOptions="Center" />
                                                    <Button Text="✕" Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.RemoveCategoryCommand}" CommandParameter="{Binding .}" Style="{StaticResource GhostButton}" Padding="0" WidthRequest="20" HeightRequest="20" TextColor="{StaticResource NodusAccent}" FontSize="10" />
                                                </HorizontalStackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </FlexLayout>
                                
                                <Label Text="Estas categorías aparecerán en el dropdown de registro para los estudiantes." Style="{StaticResource Caption2}" Margin="4,-4,4,0" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="Límite máximo de proyectos" Style="{StaticResource FormLabel}" />
                                <Entry Keyboard="Numeric" Text="{Binding MaxProjects}" Style="{StaticResource FormEntry}" Margin="0" />
                                <Label Text="El servidor dejará de aceptar registros una vez alcanzado este límite." Style="{StaticResource Caption2}" Margin="4,0" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- STEP 2: SCORING RUBRIC -->
                <VerticalStackLayout Spacing="20" IsVisible="{Binding IsStep2}">
                    <Label Text="Define los criterios con los que el jurado evaluará los proyectos." Style="{StaticResource Subhead}" HorizontalTextAlignment="Center" />

                    <Border Style="{StaticResource PremiumCard}">
                        <VerticalStackLayout Spacing="12">
                            <CollectionView ItemsSource="{Binding RubricCriteria}" SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RubricCriterionEditorItem">
                                        <Border Padding="16" Margin="0,0,0,12" BackgroundColor="{AppThemeBinding Light=#05000000, Dark=#05FFFFFF}" StrokeShape="RoundRectangle 12">
                                            <VerticalStackLayout Spacing="12">
                                                <Grid ColumnDefinitions="*, Auto">
                                                    <Entry Grid.Column="0" Placeholder="Nombre del criterio (Ej. Innovación)" Text="{Binding Label}" FontAttributes="Bold" Margin="0" />
                                                    <Button Grid.Column="1" Text="✕" Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.RemoveCriterionCommand}" CommandParameter="{Binding .}" Style="{StaticResource GhostButton}" TextColor="{StaticResource NodusError}" WidthRequest="40" Padding="0" />
                                                </Grid>
                                                
                                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                                    <VerticalStackLayout Grid.Column="0">
                                                        <Label Text="Min" Style="{StaticResource Caption2}" />
                                                        <Entry Text="{Binding Min}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
                                                    </VerticalStackLayout>
                                                    <VerticalStackLayout Grid.Column="1">
                                                        <Label Text="Max" Style="{StaticResource Caption2}" />
                                                        <Entry Text="{Binding Max}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
                                                    </VerticalStackLayout>
                                                    <VerticalStackLayout Grid.Column="2">
                                                        <Label Text="Peso (x)" Style="{StaticResource Caption2}" />
                                                        <Entry Text="{Binding Weight}" Keyboard="Numeric" HorizontalTextAlignment="Center" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <Button Text="+ Agregar criterio" Command="{Binding AddCriterionCommand}" Style="{StaticResource SecondaryButton}" HorizontalOptions="Center" Margin="0,10,0,0" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- STEP 3: SECURITY & FINISH -->
                <VerticalStackLayout Spacing="20" IsVisible="{Binding IsStep3}">
                    <Border Style="{StaticResource PremiumCard}" IsVisible="{Binding HasNoEventCreated}">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="SEGURIDAD DEL EVENTO" Style="{StaticResource SectionHeader}" Margin="0,0,0,8" />
                            <Label Text="Esta clave será necesaria para que los jueces desbloqueen su acceso después de escanear el QR." Style="{StaticResource Body}" />
                            
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Clave de acceso (Mín. 6 caracteres)" Style="{StaticResource FormLabel}" />
                                <Entry Placeholder="Clave secreta" Text="{Binding AccessPassword}" IsPassword="True" Style="{StaticResource FormEntry}" Margin="0" />
                            </VerticalStackLayout>

                            <Button Text="CREAR EVENTO Y EMPEZAR" 
                                    Command="{Binding SaveEventCommand}" 
                                    Style="{StaticResource GradientButton}" 
                                    Margin="0,20,0,0"
                                    IsEnabled="{Binding IsNotBusy}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Success State -->
                    <Border Style="{StaticResource PremiumCard}" IsVisible="{Binding SaveSucceeded}">
                        <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                            <Label Text="¡Evento creado con éxito!" Style="{StaticResource Title2}" HorizontalTextAlignment="Center" TextColor="{StaticResource NodusSuccess}" />
                            
                            <Label Text="QR de acceso para jueces" Style="{StaticResource Headline}" HorizontalTextAlignment="Center" />
                            <Image Source="{Binding JudgeAccessQrSource}" WidthRequest="250" HeightRequest="250" HorizontalOptions="Center" />
                            
                            <Label Text="Comparte este QR con el jurado y dales la clave seleccionada." Style="{StaticResource Footnote}" HorizontalTextAlignment="Center" />
                            
                            <Button Text="Ver todos los QRs" Command="{Binding DoneCommand}" Style="{StaticResource SecondaryButton}" />
                        </VerticalStackLayout>
                    </Border>
                    
                    <Border IsVisible="{Binding HasError}" BackgroundColor="{StaticResource NodusError}" Padding="16" StrokeShape="RoundRectangle 12">
                        <Label Text="{Binding ErrorMessage}" TextColor="White" Style="{StaticResource Footnote}" />
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer Navigation -->
        <Grid Grid.Row="2" ColumnDefinitions="*, *" Padding="20,10,20,20" ColumnSpacing="12" IsVisible="{Binding HasNoEventCreated}">
            <Button Grid.Column="0" Text="Anterior" Command="{Binding BackStepCommand}" IsVisible="{Binding IsStep1, Converter={StaticResource InverseBooleanConverter}}" Style="{StaticResource SecondaryButton}" />
            <Button Grid.Column="1" Text="Siguiente" Command="{Binding NextStepCommand}" IsVisible="{Binding IsStep3, Converter={StaticResource InverseBooleanConverter}}" Style="{StaticResource PrimaryButton}" HorizontalOptions="Fill" />
        </Grid>

    </Grid>

</ContentPage>
