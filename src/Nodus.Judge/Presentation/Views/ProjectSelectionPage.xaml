<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Nodus.Judge.Presentation.Views.ProjectSelectionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:Nodus.Judge.Presentation.ViewModels"
    xmlns:models="clr-namespace:Nodus.Judge.Domain.Entities"
    x:DataType="vm:VotingViewModel"
    Title="Seleccionar proyecto"
    BackgroundColor="{AppThemeBinding Light={StaticResource NodusBackground}, Dark={StaticResource NodusBackgroundDark}}">

    <ContentPage.Resources>
        <toolkit:IsStringNotNullOrWhiteSpaceConverter x:Key="StringNotEmptyConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*" Padding="0">
        <!-- Search Bar and Scan Button -->
        <Grid Grid.Row="0" Margin="16,16,16,8" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <SearchBar Grid.Column="0"
                       Placeholder="Buscar por nombre o stand..."
                       Text="{Binding SearchQuery}"
                       Margin="0" />
            <Button Grid.Column="1"
                    Text="📷 Escanear"
                    Command="{Binding OpenProjectScannerCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Padding="16,8"
                    VerticalOptions="Center" />
        </Grid>

        <!-- Progress Banner -->
        <Border Grid.Row="1" 
                Style="{StaticResource ElevatedCard}" 
                Margin="16,0,16,16" 
                Padding="16,12"
                BackgroundColor="{StaticResource NodusSurface}">
            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                <Label Text="📊" FontSize="18" VerticalOptions="Center" />
                <Label Text="{Binding SubmittedCount, StringFormat='{0} proyectos evaluados'}" 
                       Style="{StaticResource Subhead}"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

        <!-- Project List -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding FilteredProjects}"
                        SelectionMode="None">
            <!-- Ensure padding bottom for scrolling -->
            <CollectionView.Margin>
                <OnPlatform x:TypeArguments="Thickness">
                    <On Platform="iOS, Android" Value="16,0,16,32" />
                    <On Platform="WinUI, MacCatalyst" Value="16,0,16,32" />
                </OnPlatform>
            </CollectionView.Margin>
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:LocalProject">
                    <Border Style="{StaticResource Card}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:VotingViewModel}}, Path=SelectProjectCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="6">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Name}" 
                                   Style="{StaticResource Headline}" 
                                   LineBreakMode="TailTruncation" />
                            
                            <!-- Category & Stand -->
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="8">
                                <Label Text="{Binding Category}" 
                                       Style="{StaticResource Caption1}" 
                                       TextColor="{StaticResource NodusSecondaryLabel}" />
                                
                                <Border Style="{StaticResource BadgeWarning}" 
                                        IsVisible="{Binding StandNumber, Converter={StaticResource StringNotEmptyConverter}}"
                                        Padding="6,2">
                                    <Label Text="{Binding StandNumber, StringFormat='Stand {0}'}" 
                                           Style="{StaticResource Caption2}" 
                                           TextColor="{StaticResource NodusWarning}" 
                                           FontAttributes="Bold" />
                                </Border>
                            </HorizontalStackLayout>

                            <Label Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                   Text="›" 
                                   Style="{StaticResource Title1}" 
                                   TextColor="{StaticResource NodusSeparator}" 
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,48,0,0">
                    <Label Text="No se encontraron proyectos" 
                           Style="{StaticResource Headline}" 
                           HorizontalTextAlignment="Center" />
                    <Label Text="Intenta con otros términos de búsqueda" 
                           Style="{StaticResource Footnote}" 
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
