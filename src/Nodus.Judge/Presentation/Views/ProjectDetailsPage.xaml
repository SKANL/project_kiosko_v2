<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Nodus.Judge.Presentation.Views.ProjectDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:Nodus.Judge.Presentation.ViewModels"
    x:DataType="vm:ProjectDetailsViewModel"
    Title="{Binding Project.Name}"
    BackgroundColor="{AppThemeBinding Light={StaticResource NodusBackground}, Dark={StaticResource NodusBackgroundDark}}">

    <ContentPage.Resources>
        <toolkit:IsStringNotNullOrWhiteSpaceConverter x:Key="StringNotEmptyConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto" RowSpacing="12" Padding="24,20,24,12">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="20">
                
                <!-- Header Section -->
                <VerticalStackLayout Spacing="8">
                    <Label Style="{StaticResource LargeTitle}" 
                           Text="{Binding Project.Name}" 
                           LineBreakMode="WordWrap" />
                    
                    <HorizontalStackLayout Spacing="10">
                        <Border Style="{StaticResource BadgeInfo}">
                            <Label Text="{Binding Project.Category}" 
                                   Style="{StaticResource Caption1}" 
                                   TextColor="{StaticResource NodusAccent}" 
                                   FontAttributes="Bold" />
                        </Border>
                        <Border Style="{StaticResource BadgeWarning}" IsVisible="{Binding Project.StandNumber, Converter={StaticResource StringNotEmptyConverter}}">
                            <Label Text="{Binding Project.StandNumber, StringFormat='Stand {0}'}" 
                                   Style="{StaticResource Caption1}" 
                                   TextColor="{StaticResource NodusWarning}" 
                                   FontAttributes="Bold" />
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Status Card if Voted -->
                <Border Style="{StaticResource Card}" IsVisible="{Binding IsAlreadyVoted}" BackgroundColor="{StaticResource NodusSuccess}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Ya evaluado" Style="{StaticResource Headline}" TextColor="White" />
                            <Label Text="Puedes volver a evaluar para actualizar la nota." Style="{StaticResource Footnote}" TextColor="White" Opacity="0.9" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1" Text="{Binding PreviousScore}" Style="{StaticResource Title1}" TextColor="White" VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Description -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="SOBRE EL PROYECTO" Style="{StaticResource SectionHeader}" Margin="0" />
                    <Label x:Name="DescriptionBodyLabel" Text="{Binding DescriptionText}" Style="{StaticResource Body}" LineBreakMode="WordWrap" />
                    <Button
                        Text="{Binding DescriptionToggleText}"
                        Command="{Binding ToggleDescriptionCommand}"
                        Style="{StaticResource GhostButton}"
                        HorizontalOptions="Start"
                        IsVisible="{Binding CanExpandDescription}" />
                </VerticalStackLayout>

                <!-- Objectives -->
                <VerticalStackLayout Spacing="8" IsVisible="{Binding Project.Objetivos, Converter={StaticResource StringNotEmptyConverter}}">
                    <Label Text="OBJETIVOS" Style="{StaticResource SectionHeader}" Margin="0" />
                    <Label x:Name="ObjectivesBodyLabel" Text="{Binding ObjectivesText}" Style="{StaticResource Body}" LineBreakMode="WordWrap" />
                    <Button
                        Text="{Binding ObjectivesToggleText}"
                        Command="{Binding ToggleObjectivesCommand}"
                        Style="{StaticResource GhostButton}"
                        HorizontalOptions="Start"
                        IsVisible="{Binding CanExpandObjectives}" />
                </VerticalStackLayout>

                <!-- Team -->
                <VerticalStackLayout Spacing="8" IsVisible="{Binding Project.TeamMembers, Converter={StaticResource StringNotEmptyConverter}}">
                    <Label Text="EQUIPO" Style="{StaticResource SectionHeader}" Margin="0" />
                    <Label x:Name="TeamBodyLabel" Text="{Binding TeamText}" Style="{StaticResource Body}" LineBreakMode="WordWrap" />
                    <Button
                        Text="{Binding TeamToggleText}"
                        Command="{Binding ToggleTeamCommand}"
                        Style="{StaticResource GhostButton}"
                        HorizontalOptions="Start"
                        IsVisible="{Binding CanExpandTeam}" />
                </VerticalStackLayout>

                <!-- Tech Stack -->
                <VerticalStackLayout Spacing="8" IsVisible="{Binding Project.TechStack, Converter={StaticResource StringNotEmptyConverter}}">
                    <Label Text="STACK TECNOLÓGICO" Style="{StaticResource SectionHeader}" Margin="0" />
                    <Label x:Name="TechBodyLabel" Text="{Binding TechText}" Style="{StaticResource Body}" LineBreakMode="WordWrap" />
                    <Button
                        Text="{Binding TechToggleText}"
                        Command="{Binding ToggleTechCommand}"
                        Style="{StaticResource GhostButton}"
                        HorizontalOptions="Start"
                        IsVisible="{Binding CanExpandTech}" />
                </VerticalStackLayout>

                <!-- Links Section -->
                <VerticalStackLayout Spacing="12">
                    <Label Text="RECURSOS" Style="{StaticResource SectionHeader}" Margin="0" 
                           IsVisible="{Binding HasLinks}" />
                    
                    <Button Text="Ver Código en GitHub" 
                            IsVisible="{Binding Project.GithubLink, Converter={StaticResource StringNotEmptyConverter}}"
                            Command="{Binding OpenGithubCommand}"
                            Style="{StaticResource GhostButton}"
                            HorizontalOptions="Start" />

                    <Button Text="Ver Video" 
                            IsVisible="{Binding Project.VideoLink, Converter={StaticResource StringNotEmptyConverter}}"
                            Command="{Binding OpenVideoCommand}"
                            Style="{StaticResource GhostButton}"
                            HorizontalOptions="Start" />

                        <Button Text="Ver Video del Speech" 
                            IsVisible="{Binding Project.SpeechVideoLink, Converter={StaticResource StringNotEmptyConverter}}"
                            Command="{Binding OpenSpeechVideoCommand}"
                            Style="{StaticResource GhostButton}"
                            HorizontalOptions="Start" />
                </VerticalStackLayout>

                <!-- AI Outputs -->
                <Border
                    x:Name="AiSummaryCard"
                    Style="{StaticResource ElevatedCard}"
                    IsVisible="{Binding AiSummary, Converter={StaticResource StringNotEmptyConverter}}"
                    Stroke="{StaticResource NodusAccent}"
                    StrokeThickness="1">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Label Text="RESUMEN (AI)" Style="{StaticResource SectionHeader}" Margin="0" />
                            <Label Grid.Column="1" Text="{Binding AiGeneratedAt}" Style="{StaticResource Caption1}" HorizontalOptions="End" VerticalOptions="Center" IsVisible="{Binding AiGeneratedAt, Converter={StaticResource StringNotEmptyConverter}}" />
                        </Grid>

                        <Label
                            Text="{Binding AiSummary}"
                            Style="{StaticResource Body}"
                            LineBreakMode="WordWrap"
                            LineHeight="1.25" />

                        <HorizontalStackLayout Spacing="8">
                            <Button Text="Copiar" Style="{StaticResource GhostButton}" Command="{Binding CopyAiSummaryCommand}" IsEnabled="{Binding IsNotBusy}" />
                            <Button Text="Ver completo" Style="{StaticResource GhostButton}" IsVisible="{Binding IsAiTruncated}" Command="{Binding ShowFullAiCommand}" IsEnabled="{Binding IsNotBusy}" />
                            <Button Text="Ver JSON" Style="{StaticResource GhostButton}" IsVisible="{Binding IsRawAvailable}" Command="{Binding ShowRawAiCommand}" IsEnabled="{Binding IsNotBusy}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                

            </VerticalStackLayout>
        </ScrollView>

        <!-- Action Button -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" StrokeThickness="0">
            <VerticalStackLayout Padding="0,10,0,0" Spacing="8">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" IsVisible="{Binding IsBusy}" Padding="4,0">
                    <ActivityIndicator IsRunning="{Binding IsBusy}" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Generando resumen AI..." Style="{StaticResource Footnote}" VerticalOptions="Center" />
                </Grid>

                <Button
                    Text="{Binding AiActionText}"
                    Style="{StaticResource GhostButton}"
                    Command="{Binding GenerateAiSummaryCommand}"
                    IsEnabled="{Binding IsNotBusy}" />

                <Button
                    Text="{Binding EvaluateButtonText}"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding EvaluateCommand}"
                    IsEnabled="{Binding IsNotBusy}" />

                <Button
                    Text="Volver a la lista"
                    Style="{StaticResource GhostButton}"
                    Command="{Binding BackCommand}"
                    IsEnabled="{Binding IsNotBusy}" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
